<style>
    /* Cinematic Button Loading State */
    .btn-luxe.loading {
        background: var(--obsidian);
        border: 1px solid var(--gold);
        color: var(--gold);
        cursor: wait;
        position: relative;
    }
    
    .btn-luxe.loading::after {
        content: "💿";
        position: absolute;
        right: 20px;
        animation: spin 2s linear infinite;
    }

    @keyframes spin {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }

    /* Input Validation Glow */
    input.invalid {
        border-bottom: 1px solid #ff4444 !important;
        box-shadow: 0 5px 15px rgba(255, 68, 68, 0.1);
    }
</style>

<script>
    // 1. Navigation Controller
    function nav(id, el) {
        document.querySelectorAll('.page-layer').forEach(p => p.classList.remove('active'));
        document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
        const target = document.getElementById('page-' + id);
        if(target) target.classList.add('active');
        el.classList.add('active');
    }

    // 2. Advanced Deployment Engine
    async function submitRelease() {
        const btn = event.target;
        const artist = document.getElementById('track-artist').value;
        const title = document.getElementById('track-title').value;
        
        // Metadata Compliance Check
        if(!artist || !title) {
            alert("SDR COMPLIANCE ERROR: Metadata is incomplete.");
            return;
        }

        // Cinematic Animation Start
        btn.classList.add('loading');
        btn.innerText = "PACKAGING MASTER...";

        // Simulate "Worldwide" Processing
        setTimeout(() => {
            btn.classList.remove('loading');
            btn.innerText = "DEPLOYMENT SUCCESSFUL";
            
            // Create a "Receipt" for the artist
            const receipt = `SDR_DEPLOYMENT_LOG:
            -------------------------
            ARTIST: ${artist}
            TITLE: ${title}
            DISTRO: Static Plastic (SA)
            STATUS: Pending Partner Review
            -------------------------`;
            
            console.log(receipt);
            alert("SUCCESS: Your release has been packaged according to Static Plastic standards and is ready for final delivery.");
            
            // Reset for next release
            setTimeout(() => { btn.innerText = "Initiate Deployment"; }, 3000);
        }, 2500);
    }

    // 3. Service Worker Registration (The Offline Engine)
    if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
            navigator.serviceWorker.register('./sw.js')
                .then(reg => console.log('SDR Engine: Online'))
                .catch(err => console.log('SDR Engine: Offline Sync Active'));
        });
    }

    // 4. PWA Installer Logic (Your custom sheet)
    let deferredPrompt;
    const sheet = document.getElementById('install-sheet');
    const overlay = document.getElementById('overlay');

    window.addEventListener('beforeinstallprompt', (e) => {
        e.preventDefault();
        deferredPrompt = e;
    });

    function installApp() {
        if (deferredPrompt) {
            sheet.classList.add('show');
            overlay.classList.add('show');
        } else {
            alert("SDR Portal is already optimized. For iOS: Tap 'Share' then 'Add to Home Screen'.");
        }
    }

    async function triggerNativeInstall() {
        closeSheet();
        if (!deferredPrompt) return;
        deferredPrompt.prompt();
        const { outcome } = await deferredPrompt.userChoice;
        deferredPrompt = null;
    }

    function closeSheet() {
        sheet.classList.remove('show');
        overlay.classList.remove('show');
    }
</script>
