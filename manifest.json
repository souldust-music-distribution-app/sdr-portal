<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SDR | Elite Artist Portal</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@100;300;600;900&display=swap');

        :root { 
            --gold: #c5a059; 
            --deep-gold: #996515;
            --obsidian: #050505;
            --glass: rgba(15, 12, 10, 0.95);
            --border: rgba(197, 160, 89, 0.2);
        }

        body {
            margin: 0; font-family: 'Outfit', sans-serif;
            background: var(--obsidian); color: #fff;
            height: 100vh; overflow: hidden;
        }

        /* Ambient Cinematic Background */
        .bg-glow {
            position: fixed; inset: 0;
            background: radial-gradient(circle at 50% 50%, #1a1510 0%, #050505 80%);
            z-index: -1;
        }

        .app-shell { display: flex; height: 100vh; padding: 20px; box-sizing: border-box; gap: 20px; }

        /* Sidebar Navigation */
        .nav-sidebar { 
            width: 280px; background: var(--glass); border-radius: 35px;
            border: 1px solid var(--border); display: flex; flex-direction: column; 
            padding: 35px; backdrop-filter: blur(40px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.6);
        }

        .nav-item { 
            padding: 18px; margin-bottom: 10px; border-radius: 18px; cursor: pointer; 
            transition: 0.4s cubic-bezier(0.175, 0.885, 0.32, 1);
            color: #777; display: flex; align-items: center; gap: 12px;
            font-size: 0.75rem; font-weight: 600; letter-spacing: 2px; text-transform: uppercase;
        }

        .nav-item:hover, .nav-item.active { 
            background: linear-gradient(135deg, rgba(197, 160, 89, 0.15), transparent);
            color: var(--gold); border: 1px solid var(--gold); transform: translateX(8px);
        }

        /* Main Experience Stage */
        .main-stage { 
            flex: 1; background: var(--glass); border-radius: 35px;
            border: 1px solid var(--border); overflow-y: auto; 
            padding: 50px; position: relative;
        }

        .page-layer { display: none; animation: slideReveal 0.8s ease forwards; }
        .page-layer.active { display: block; }

        @keyframes slideReveal { 
            from { opacity: 0; transform: translateY(20px); filter: blur(10px); } 
            to { opacity: 1; transform: translateY(0); filter: blur(0); } 
        }

        /* World-Class Form Styling */
        .glass-card { 
            background: rgba(255,255,255,0.02); padding: 35px; border-radius: 25px; 
            border: 1px solid var(--border); margin-bottom: 25px; position: relative;
            overflow: hidden;
        }

        .gold-label { color: var(--gold); text-transform: uppercase; letter-spacing: 4px; font-size: 0.65rem; font-weight: 900; margin-bottom: 12px; display: block; }

        input, select { 
            width: 100%; background: transparent; border: none; border-bottom: 1px solid var(--border);
            padding: 12px 0; color: #fff; font-size: 1.1rem; margin-bottom: 25px; outline: none;
            transition: 0.3s;
        }
        input:focus { border-bottom: 1px solid var(--gold); }

        .btn-luxe {
            padding: 20px 40px; background: linear-gradient(45deg, var(--deep-gold), var(--gold));
            border: none; border-radius: 50px; color: #fff; font-weight: 900;
            text-transform: uppercase; letter-spacing: 3px; cursor: pointer; transition: 0.4s;
            box-shadow: 0 10px 25px rgba(153, 101, 21, 0.2);
        }
        .btn-luxe:hover { transform: translateY(-3px); box-shadow: 0 15px 30px rgba(197, 160, 89, 0.4); }

        /* PWA Install Sheet UI */
        #install-sheet {
            position: fixed; bottom: -110%; left: 0; width: 100%; 
            background: var(--glass); border-top: 1px solid var(--gold);
            padding: 50px; border-radius: 40px 40px 0 0; backdrop-filter: blur(60px);
            transition: 0.7s cubic-bezier(0.19, 1, 0.22, 1); z-index: 10000; text-align: center;
        }
        #install-sheet.show { bottom: 0; }
        #overlay {
            position: fixed; inset: 0; background: rgba(0,0,0,0.85); 
            display: none; z-index: 9999;
        }
        #overlay.show { display: block; }
    </style>
</head>
<body>

    <div class="bg-glow"></div>

    <div class="app-shell">
        <aside class="nav-sidebar">
            <div style="text-align: center; margin-bottom: 45px;">
                <h1 style="font-weight: 100; letter-spacing: 12px; margin:0; font-size: 1.2rem;">SOUL<span style="font-weight: 900; color: var(--gold);">DUST</span></h1>
                <p style="font-size: 0.55rem; color: var(--gold); letter-spacing: 4px; margin-top: 5px;">WORLDWIDE PORTAL</p>
            </div>
            <div class="nav-item active" onclick="nav('home', this)">Hub</div>
            <div class="nav-item" id="shortcut-submit" onclick="nav('release', this)">Distribution</div>
            <div class="nav-item" onclick="nav('sync', this)">Static Bridge</div>
            <div class="nav-item" onclick="nav('ledger', this)">Ledger</div>
            
            <div class="nav-item" style="margin-top: auto; color: var(--gold); border: 1px solid var(--gold);" onclick="installApp()">📲 Install App</div>
        </aside>

        <main class="main-stage">
            <div id="page-home" class="page-layer active">
                <span class="gold-label">Artist Command</span>
                <h2 style="font-size: 2.5rem; margin-top: 0;">Welcome to the Elite</h2>
                <div class="glass-card">
                    <p style="opacity: 0.8; line-height: 1.6;">Your creative output is synced with <b>Static Plastic</b> (SA) for global reach. Ensure all audio masters meet the 16-bit / 44.1kHz standard before deployment.</p>
                </div>
            </div>

            <div id="page-release" class="page-layer">
                <span class="gold-label">Music Submission</span>
                <h2 style="font-size: 2.5rem; margin-top: 0;">New Release</h2>
                <div class="glass-card">
                    <label class="gold-label">Primary Artist & Title</label>
                    <input type="text" id="track-artist" placeholder="Primary Artist (e.g. Nontomby)">
                    <input type="text" id="track-title" placeholder="Song Name (e.g. Impumelelo)">
                    
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                        <div>
                            <label class="gold-label">Catalogue No.</label>
                            <input type="text" placeholder="e.g. SDR001">
                        </div>
                        <div>
                            <label class="gold-label">Mix Name</label>
                            <input type="text" placeholder="e.g. Original Mix">
                        </div>
                    </div>
                    
                    <label class="gold-label">Audio Quality Check</label>
                    <select>
                        <option>16-bit / 44.1kHz WAV (Required)</option>
                        <option>24-bit / 48kHz (High Res)</option>
                    </select>

                    <button class="btn-luxe" onclick="submitRelease()">Initiate Deployment</button>
                </div>
            </div>

            <div id="page-sync" class="page-layer">
                <span class="gold-label">Partner Gateway</span>
                <h2 style="font-size: 2.5rem; margin-top: 0;">Static Plastic Sync</h2>
                <div class="glass-card">
                    <p style="font-size: 0.9rem; opacity: 0.7;">Submit your completed Metadata Sheets and Distribution Agreements here for final processing by Static Plastic.</p>
                    <div style="border: 1px dashed var(--gold); padding: 40px; text-align: center; border-radius: 20px;">
                        <button class="btn-luxe" style="background: transparent; border: 1px solid var(--gold);">Upload CSV / PDF</button>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <div id="overlay" onclick="closeSheet()"></div>
    <div id="install-sheet">
        <h2 style="color: var(--gold); font-size: 2rem;">Unleash the Power</h2>
        <p style="opacity: 0.8; margin-bottom: 30px;">Add the SDR Portal to your home screen for instant artist resources and distribution tools.</p>
        <button class="btn-luxe" onclick="triggerNativeInstall()">Install Now</button>
        <p style="margin-top: 25px; font-size: 0.8rem; cursor: pointer; opacity: 0.4;" onclick="closeSheet()">Dismiss</p>
    </div>

    <script>
        // 1. Navigation Controller
        function nav(id, el) {
            document.querySelectorAll('.page-layer').forEach(p => p.classList.remove('active'));
            document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
            document.getElementById('page-' + id).classList.add('active');
            el.classList.add('active');
        }

        // 2. Deployment Logic
        function submitRelease() {
            const artist = document.getElementById('track-artist').value;
            const title = document.getElementById('track-title').value;
            if(!artist || !title) return alert("All fields are required for metadata compliance.");
            alert(`SDR ENGINE: Packaging ${artist} - ${title} for Global Stores.`);
        }

        // 3. PWA Installer Logic
        let deferredPrompt;
        const sheet = document.getElementById('install-sheet');
        const overlay = document.getElementById('overlay');

        window.addEventListener('beforeinstallprompt', (e) => {
            e.preventDefault();
            deferredPrompt = e;
            console.log("SDR Installer Ready");
        });

        function installApp() {
            if (deferredPrompt) {
                sheet.classList.add('show');
                overlay.classList.add('show');
            } else {
                alert("SDR Portal is already optimized. For iOS: Tap 'Share' then 'Add to Home Screen'.");
            }
        }

        async function triggerNativeInstall() {
            closeSheet();
            if (!deferredPrompt) return;
            deferredPrompt.prompt();
            const { outcome } = await deferredPrompt.userChoice;
            if (outcome === 'accepted') console.log('Artist installed the SDR Elite App');
            deferredPrompt = null;
        }

        function closeSheet() {
            sheet.classList.remove('show');
            overlay.classList.remove('show');
        }
    </script>
</body>
</html>
