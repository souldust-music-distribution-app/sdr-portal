let deferredPrompt;
const sheet = document.getElementById('install-sheet');
const overlay = document.getElementById('overlay');

// 1. Capture the browser install signal
window.addEventListener('beforeinstallprompt', (e) => {
    e.preventDefault();
    deferredPrompt = e;
    console.log("SDR Installer Ready");
});

// 2. This runs when they click your "INSTALL APP" button
function installApp() {
    if (deferredPrompt) {
        // Show the cool bottom sheet
        sheet.classList.add('show');
        overlay.classList.add('show');
    } else {
        // Fallback for iOS/Browsers that already installed it
        alert("SDR Portal is already optimized. If on iPhone: Tap 'Share' then 'Add to Home Screen'.");
    }
}

// 3. This runs when they click "INSTALL NOW" inside the sheet
async function triggerNativeInstall() {
    closeSheet();
    if (!deferredPrompt) return;
    
    deferredPrompt.prompt();
    const { outcome } = await deferredPrompt.userChoice;
    
    if (outcome === 'accepted') {
        console.log('Artist installed the SDR Elite App');
    }
    deferredPrompt = null;
}

function closeSheet() {
    sheet.classList.remove('show');
    overlay.classList.remove('show');
}
