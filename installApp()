<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SDR | Power Portal 2026</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@100;300;600;900&display=swap');

        :root { 
            --gold: #c5a059; 
            --deep-gold: #996515;
            --obsidian: #0a0a0a;
            --glass: rgba(15, 12, 10, 0.9);
            --border: rgba(197, 160, 89, 0.25);
        }

        body {
            margin: 0; font-family: 'Outfit', sans-serif;
            background: var(--obsidian); color: #fff;
            height: 100vh; overflow: hidden;
        }

        .bg-glow {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: radial-gradient(circle at 50% 50%, #2a1f10 0%, #0a0a0a 70%);
            z-index: -1;
        }

        .app-shell { display: flex; height: 100vh; width: 100vw; padding: 25px; box-sizing: border-box; gap: 25px; }

        /* Sidebar */
        .nav-sidebar { 
            width: 300px; background: var(--glass); border-radius: 40px;
            border: 1px solid var(--border); display: flex; flex-direction: column; 
            padding: 40px; backdrop-filter: blur(40px);
            box-shadow: 0 25px 50px rgba(0,0,0,0.8);
        }

        .nav-item { 
            padding: 20px; margin-bottom: 15px; border-radius: 20px; cursor: pointer; 
            transition: 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            color: #888; display: flex; align-items: center; gap: 15px;
            font-size: 0.8rem; font-weight: 600; letter-spacing: 2px; text-transform: uppercase;
        }

        .nav-item:hover, .nav-item.active { 
            background: linear-gradient(135deg, rgba(197, 160, 89, 0.2), transparent);
            color: var(--gold); border: 1px solid var(--gold); transform: translateX(10px);
        }

        .main-content { 
            flex: 1; background: var(--glass); border-radius: 40px;
            border: 1px solid var(--border); overflow-y: auto; 
            padding: 60px; position: relative;
        }

        .page-layer { display: none; animation: slideUp 0.8s ease; }
        .page-layer.active { display: block; }

        @keyframes slideUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }

        /* Cinematic Elements */
        .gold-text { color: var(--gold); text-transform: uppercase; letter-spacing: 5px; font-size: 0.7rem; display: block; margin-bottom: 10px; }
        h2 { font-size: 2.5rem; font-weight: 900; margin-bottom: 30px; letter-spacing: -1px; }

        .glass-card { 
            background: rgba(255,255,255,0.03); padding: 30px; border-radius: 30px; 
            border: 1px solid var(--border); margin-bottom: 25px;
        }

        input, select { 
            width: 100%; background: transparent; border: none; border-bottom: 1px solid var(--border);
            padding: 15px 0; color: #fff; font-size: 1.1rem; margin-bottom: 25px; outline: none;
        }

        .btn-luxe {
            padding: 20px 40px; background: linear-gradient(45deg, var(--deep-gold), var(--gold));
            border: none; border-radius: 100px; color: #fff; font-weight: 900;
            text-transform: uppercase; letter-spacing: 3px; cursor: pointer; transition: 0.4s;
        }

        /* PWA Install Sheet */
        #install-sheet {
            position: fixed; bottom: -100%; left: 0; width: 100%; 
            background: var(--glass); border-top: 1px solid var(--gold);
            padding: 40px; border-radius: 40px 40px 0 0; backdrop-filter: blur(50px);
            transition: 0.6s cubic-bezier(0.19, 1, 0.22, 1); z-index: 10000; text-align: center;
        }
        #install-sheet.show { bottom: 0; }
        #overlay {
            position: fixed; inset: 0; background: rgba(0,0,0,0.8); 
            display: none; z-index: 9999;
        }
        #overlay.show { display: block; }

        .hidden { display: none !important; }
    </style>
</head>
<body>

    <div class="bg-glow"></div>

    <div class="app-shell">
        <aside class="nav-sidebar">
            <div style="text-align: center; margin-bottom: 40px;">
                <h1 style="font-weight: 100; letter-spacing: 10px;">SDR</h1>
                <p style="font-size: 0.6rem; color: var(--gold); letter-spacing: 3px;">2026 WORLDWIDE</p>
            </div>
            <div class="nav-item active" onclick="showTab('home', this)">🏠 Dashboard</div>
            <div class="nav-item" onclick="showTab('release', this)">🚀 Release</div>
            <div class="nav-item" onclick="showTab('static', this)">🔄 Static Sync</div>
            <div class="nav-item" onclick="showTab('wallet', this)">💰 Ledger</div>
            <div class="nav-item" style="margin-top: auto; border: 1px solid var(--gold); color: var(--gold);" onclick="installApp()">📲 Install App</div>
        </aside>

        <main class="main-content">
            <div id="page-home" class="page-layer active">
                <span class="gold-text">Welcome Back</span>
                <h2>Label Headquarters</h2>
                <div class="glass-card">
                    <h3 style="color: var(--gold);">Global Distribution Engine</h3>
                    <p style="opacity: 0.7;">System status: Syncing with Static Plastic (South Africa). 16-bit WAV processing active.</p>
                </div>
            </div>

            <div id="page-release" class="page-layer">
                <span class="gold-text">New Submission</span>
                <h2>Cinematic Metadata</h2>
                <div class="glass-card">
                    <label class="gold-text">Title & Artist</label>
                    <input type="text" placeholder="Track Title (e.g. Impumelelo)">
                    <input type="text" placeholder="Primary Artist (e.g. Nontomby)">
                    
                    <label class="gold-text">Technical Specs (Strict)</label>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                        <select>
                            <option>16-bit / 44.1kHz WAV</option>
                            <option>24-bit / 48kHz (Not Advised)</option>
                        </select>
                        <input type="text" placeholder="CAT Number (e.g. SDR001)">
                    </div>
                    <button class="btn-luxe" onclick="alert('Mastering checks passed. Uploading...')">Push to Distributor</button>
                </div>
            </div>

            <div id="page-wallet" class="page-layer">
                <span class="gold-text">Financials</span>
                <h2>The Golden Vault</h2>
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                    <div class="glass-card">
                        <span class="gold-text">Current Balance</span>
                        <h1 style="margin:0;">R 0.00</h1>
                    </div>
                    <div class="glass-card">
                        <span class="gold-text">Next Payout</span>
                        <h1 style="margin:0;">R 0.00</h1>
                    </div>
                </div>
                <div class="glass-card">
                    <h4 style="color:var(--gold)">Recent Statements</h4>
                    <p style="opacity:0.5; font-size:0.8rem;">Waiting for sync from Static Plastic Distribution portal.</p>
                </div>
            </div>
        </main>
    </div>

    <div id="overlay" onclick="closeSheet()"></div>
    <div id="install-sheet">
        <h2 style="color: var(--gold);">Install SDR Elite</h2>
        <p>Get the full cinematic experience on your home screen. Fast, secure, and ready for power.</p>
        <button class="btn-luxe" onclick="triggerNativeInstall()">Install Now</button>
        <p style="margin-top: 20px; font-size: 0.8rem; cursor: pointer; opacity: 0.5;" onclick="closeSheet()">Maybe later</p>
    </div>

    <script>
        // 1. Navigation Logic
        function showTab(id, el) {
            document.querySelectorAll('.page-layer').forEach(p => p.classList.remove('active'));
            document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
            document.getElementById('page-' + id).classList.add('active');
            el.classList.add('active');
        }

        // 2. PWA Installer Logic
        let deferredPrompt;
        const sheet = document.getElementById('install-sheet');
        const overlay = document.getElementById('overlay');

        window.addEventListener('beforeinstallprompt', (e) => {
            e.preventDefault();
            deferredPrompt = e;
            console.log("SDR Installer Ready");
        });

        function installApp() {
            if (deferredPrompt) {
                sheet.classList.add('show');
                overlay.classList.add('show');
            } else {
                alert("SDR Portal is already optimized. For iPhone: Tap 'Share' then 'Add to Home Screen'.");
            }
        }

        async function triggerNativeInstall() {
            closeSheet();
            if (!deferredPrompt) return;
            deferredPrompt.prompt();
            const { outcome } = await deferredPrompt.userChoice;
            if (outcome === 'accepted') console.log('User installed SDR Portal');
            deferredPrompt = null;
        }

        function closeSheet() {
            sheet.classList.remove('show');
            overlay.classList.remove('show');
        }
    </script>
</body>
</html>
